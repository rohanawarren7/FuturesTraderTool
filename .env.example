# VWAP Trading Bot - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# =============================================================================
# BROKER CONFIGURATION - CHOOSE ONE
# =============================================================================

# Option 1: Interactive Brokers (TWS) - RECOMMENDED, 100% FREE
# -------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
# Port 7497 = Paper Trading, Port 7496 = Live Trading
# Make sure TWS is running with API enabled

# Option 2: Tradovate - $25/month API fee
# ----------------------------------------
# TRADOVATE_USERNAME=your_tradovate_username
# TRADOVATE_PASSWORD=your_tradovate_password
# TRADOVATE_APP_ID=your_app_id
# TRADOVATE_USE_DEMO=true

# =============================================================================
# DATABASE
# =============================================================================
DB_PATH=./database/trading_analysis.db

# =============================================================================
# PROP FIRM CONFIGURATION
# =============================================================================
PROP_FIRM=TOPSTEP_50K
# Options: TOPSTEP_50K, TOPSTEP_100K, APEX_50K, APEX_100K, FTMO_100K

# =============================================================================
# WEBHOOK SERVER SECURITY
# =============================================================================
# Make up random strings for these (any random text)
TV_WEBHOOK_SECRET=your_webhook_secret_change_this_to_random_string
ADMIN_SECRET=your_admin_secret_change_this_to_random_string

# =============================================================================
# VIDEO ANALYSIS (Optional - for pattern mining)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# NOTIFICATIONS (Optional)
# =============================================================================
# SLACK_WEBHOOK_URL=your_slack_webhook
# NOTIFICATION_EMAIL=your@email.com

# =============================================================================
# LOGGING (Optional)
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# =============================================================================
# NOTES
# =============================================================================
# 
# For Interactive Brokers (FREE):
#   1. Download TWS from https://www.interactivebrokers.com
#   2. Enable API: Edit → Global Config → API → Settings
#   3. Check "ActiveX and Socket Clients"
#   4. Set port to 7497 (paper) or 7496 (live)
#   5. Install: pip install ib_insync
#   6. Run: python scripts/setup_ibkr_account.py
#
# For Tradovate ($25/month):
#   1. Create account at https://www.tradovate.com
#   2. Go to Settings → API Access
#   3. Create app to get App ID
#   4. Uncomment Tradovate settings above
#   5. Run: python scripts/setup_demo_account.py
#
# After setup, run validation:
#   python scripts/validate_paper_trading.py
#
# Then start trading:
#   uvicorn execution.webhook_server_enhanced:app --host 0.0.0.0 --port 8000
